{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "leitwerk-hook-guard",
            "statusMessage": "Checking the target is not a human-owned file...",
            "timeout": 30
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "leitwerk verify --tier ${LEITWERK_TIER:-T1} || exit 2",
            "statusMessage": "Running the leitwerk gate before ending the turn...",
            "timeout": 600
          }
        ]
      }
    ]
  }
}
