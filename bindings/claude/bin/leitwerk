#!/usr/bin/env bash
# Launcher: the plugin's bin/ is on the Bash PATH when the plugin is enabled, so
# skills and hooks can call `leitwerk` by name. This shim locates the real
# tool-agnostic core CLI (bindings never reimplement the gate).
#
# A marketplace install sparse-copies ONLY this plugin dir, so core/ is NOT next
# to it — an adopter must supply the core binary via LEITWERK_HOME or a global
# install (`go install`). The relative paths below resolve only in a full-repo
# checkout (development).
#
# Resolution order:
#   1. $LEITWERK_HOME/bin/leitwerk         (explicit install — the adopter path)
#   2. core/ in the same checkout          (full-repo clone / dev only)
#   3. a vendored core/ next to the plugin (only if one was deliberately copied)
#   4. a globally installed CLI            (go install …/core/cmd/leitwerk@latest)
set -euo pipefail
SELF_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

for cand in \
  "${LEITWERK_HOME:-}/bin/leitwerk" \
  "$SELF_DIR/../../../core/bin/leitwerk" \
  "$SELF_DIR/../core/bin/leitwerk"; do
  if [ -n "$cand" ] && [ -x "$cand" ]; then exec "$cand" "$@"; fi
done

real="$(command -v -a leitwerk 2>/dev/null | grep -vF "$SELF_DIR/leitwerk" | head -1 || true)"
if [ -n "$real" ]; then exec "$real" "$@"; fi

echo "leitwerk: core CLI not found. Install it with: go install github.com/cf-sewe/leitwerk-devkit/core/cmd/leitwerk@latest" >&2
echo "         (or set LEITWERK_HOME to the core/ directory of a checkout)" >&2
exit 127
