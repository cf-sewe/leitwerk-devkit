{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/bindings/claude/bin/leitwerk-hook-guard\"",
            "statusMessage": "Checking the target is not a human-owned file...",
            "timeout": 30
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/core/bin/leitwerk\" verify --tier ${LEITWERK_TIER:-T2} || exit 2",
            "statusMessage": "Running the leitwerk gate on the repo itself...",
            "timeout": 600
          }
        ]
      }
    ]
  }
}
